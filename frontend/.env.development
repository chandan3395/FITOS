# Development-only bypass that skips the real auth flow and injects a
# mock user. Only honored when:
#   import.meta.env.DEV === true     (i.e. `vite` dev server)
#   AND this flag equals "true".
#
# This file is loaded by Vite ONLY in development mode. Production
# builds (`vite build`) never see it.
VITE_DEV_AUTH_BYPASS=true
