# ─── Frontend-only ──────────────────────────────────────────
# Only VITE_-prefixed variables are exposed to the client bundle.
# All backend secrets (Mongo, JWT, OAuth, Cloudinary, WhatsApp, Sentry)
# live in backend/.env — never duplicate them here.

# Set to "false" to temporarily hide the "Continue with Google" CTA on
# the login page. Backend must also set ENABLE_GOOGLE_AUTH=false so the
# OAuth routes return 503. Defaults to enabled.
VITE_ENABLE_GOOGLE_AUTH=true

# ─── Dev QA tools (safe — no auth bypass) ───────────────────
# The QA quick-login panel auto-renders on the Vite dev server. Set this to
# "true" to also render it in a production-style build (e.g. a staging host).
# It performs REAL logins against seeded qa-*@fitos.local accounts; it never
# bypasses authentication. Leave unset/false for real production.
VITE_SHOW_QA_TOOLS=false

# Optional — overrides the QA password the panel uses. Must match QA_PASSWORD
# used by backend/scripts/seed-qa-users.js. Defaults to "qa-password-123".
VITE_QA_PASSWORD=
