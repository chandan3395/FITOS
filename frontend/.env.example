PORT=

MONGODB_URI=

JWT_SECRET=

GOOGLE_CLIENT_ID=

GOOGLE_CLIENT_SECRET=

CLOUDINARY_CLOUD_NAME=

CLOUDINARY_API_KEY=

CLOUDINARY_API_SECRET=

WHATSAPP_API_KEY=

# ── Dev-only ─────────────────────────────────────────────────────
# Set to "true" to bypass auth in development. Honored only when
# import.meta.env.DEV is true (i.e. `vite` dev server). Production
# builds (`vite build`) hard-strip the bypass at compile time, so
# this value is irrelevant in any shipped bundle.
VITE_DEV_AUTH_BYPASS=false

# Set to "false" to temporarily hide the "Continue with Google" CTA on
# the login page. Backend must also set ENABLE_GOOGLE_AUTH=false so the
# OAuth routes return 503. Defaults to enabled.
VITE_ENABLE_GOOGLE_AUTH=true
