{
  "name": "fitos-backend",
  "version": "1.0.0",
  "description": "FITOS backend API server",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "echo \"No build step for Node.js backend\"",
    "test": "jest --colors",
    "lint": "eslint src",
    "create-admin": "node scripts/create-first-admin.js",
    "seed:demo": "node scripts/seedDemoEnvironment.js",
    "migrate:nutrition-v2": "node scripts/migrateNutritionScheduleV2.js",
    "migrate:workout-v2": "node scripts/migrateWorkoutSetDetailsV2.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "verbose": true
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@sentry/node": "^10.65.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "supertest": "^7.2.2"
  }
}
