# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Frontend origin (CORS allow-list + OAuth redirect base)
CLIENT_ORIGIN=http://localhost:5173

# ─── Database ────────────────────────────────────────────────
MONGO_URI=

# ─── JWT secrets (must be long random strings, different from each other) ─
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── Google OAuth ────────────────────────────────────────────
# Set ENABLE_GOOGLE_AUTH=false to disable the feature entirely; OAuth
# routes return 503 and passport is never initialised. When false the
# GOOGLE_* secrets below may be left blank.
ENABLE_GOOGLE_AUTH=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ─── Dev-only ────────────────────────────────────────────────
# When "true", authenticate() skips JWT and resolves req.user from the
# x-dev-role (and, for CLIENT, x-dev-client-id) headers — auto-creating
# stable dev-<role>@fitos.local users with real ObjectIds. Also unlocks
# /api/dev/* tooling endpoints. NEVER enable in production.
DEV_AUTH_BYPASS=false

# ─── Cloudinary (required) ───────────────────────────────────
# Backs progress-photo storage via signed direct uploads. All three are
# required — the server fails fast on startup if any is missing.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Reserved for future phases (do not set yet) ─────────────
# WhatsApp Business API — used to deliver client activation links.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Sentry (optional) — error/perf monitoring.
SENTRY_DSN=
